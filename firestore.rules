rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isMember(workspaceId) {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId == workspaceId;
    }

    function isOwner(workspaceId) {
      return request.auth != null
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.createdBy == request.auth.uid;
    }

    // ── Workspace ─────────────────────────────────────────────────────────────

    match /workspaces/{workspaceId} {
      allow read:   if isMember(workspaceId)
                    || (request.auth != null
                        && 'allowedEmails' in resource.data
                        && request.auth.token.email in resource.data.allowedEmails);
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // Members can update, but only owners can change createdBy or allowedEmails
      allow update: if isMember(workspaceId)
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['createdBy', 'allowedEmails'])
                        || isOwner(workspaceId));
      allow delete: if isOwner(workspaceId);

      // Members sub-collection
      match /members/{memberId} {
        allow read:  if isMember(workspaceId);
        // Owners can write any member doc (set roles, remove, etc.)
        allow write: if isOwner(workspaceId);
        // Non-owners can only create their own doc with role='member'
        allow create: if request.auth != null
                      && request.auth.uid == memberId
                      && request.resource.data.role == 'member';
        // Non-owners can update their own doc but cannot change role
        allow update: if request.auth != null
                      && request.auth.uid == memberId
                      && request.resource.data.role == resource.data.role;
      }

      // Invites — owner creates; joining user can only set usedBy to self
      match /invites/{inviteId} {
        allow create: if isOwner(workspaceId);
        allow read:   if request.auth != null;
        allow update: if request.auth != null
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy'])
                      && request.resource.data.usedBy == request.auth.uid;
        allow delete: if isOwner(workspaceId);
      }

      // ── CRM data collections ───────────────────────────────────────────────

      match /leads/{leadId} {
        allow read, write: if isMember(workspaceId);
      }

      match /notes/{noteId} {
        allow read:   if isMember(workspaceId);
        allow create: if isMember(workspaceId);
        allow update, delete: if false;
      }

      match /pipelines/{pipelineId} {
        allow read:  if isMember(workspaceId);
        allow write: if isOwner(workspaceId);
      }

      match /sprints/{sprintId} {
        allow read, write: if isMember(workspaceId);
      }

      match /callingLists/{listId} {
        allow read, write: if isMember(workspaceId);
      }
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Ejection: workspace owner can clear workspaceId on a removed member
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['workspaceId', 'ejectedAt'])
                    && isOwner(resource.data.workspaceId);

      match /syncQueue/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }
  }
}

# Pluto CRM Environment Variables Template
# Copy this file to '.env' and fill in your admin credentials.
# DISCLAIMER: Client-side variables are bundled into production. Do not store sensitive backend API keys here.

VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=pluto2026

# Firebase Client Configuration (Phase 2)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
